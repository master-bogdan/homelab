# App
APP_ENV=DEV
FRONTEND_BASE_URL=http://localhost:5173

# Server
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=DEBUG
PASETO_SYMMETRIC_KEY=0123456789abcdef0123456789abcdef
ISSUER=http://localhost:8080
HTTP_ALLOWED_ORIGINS=http://localhost:5173
WS_ALLOWED_ORIGINS=http://localhost:5173
TRUST_PROXY_HEADERS=false
HTTP_RATE_LIMIT_PER_MINUTE=100
WS_RATE_LIMIT_PER_MINUTE=120

# DB
DATABASE_URL=postgres://postgres:password@localhost:5432/estimate_room?sslmode=disable
REDIS_URL=redis://localhost:6379/0
IS_AUTO_MIGRATIONS=true

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=
GITHUB_STATE_SECRET=
GITHUB_SCOPES=read:user user:email

# Email
EMAIL_FROM=no-reply@estimate-room.dev
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
